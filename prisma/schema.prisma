// ─── SPZ Weihnachtsfeier Buchungstool ────────────────────────
// Prisma Schema – PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════
// Venue & Raumplan
// ═══════════════════════════════════════════════════════════════

model Venue {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  areas         Area[]
  tableGroups   TableGroup[]
  timeSlots     TimeSlot[]
  dateConfigs   DateConfig[]
  capacityRules CapacityRule[]
  seasonConfig  SeasonConfig?
  addOns        AddOn[]
  bookings      Booking[]
  curlingLanes  CurlingLane[]
}

model Area {
  id        String @id @default(cuid())
  venueId   String
  name      String
  sortOrder Int    @default(0)

  venue  Venue   @relation(fields: [venueId], references: [id], onDelete: Cascade)
  tables Table[]

  @@index([venueId])
}

model Table {
  id       String     @id @default(cuid())
  areaId   String
  label    String
  seats    Int        @default(10)
  posX     Float      @default(0)
  posY     Float      @default(0)
  width    Float      @default(80)
  height   Float      @default(80)
  shape    TableShape @default(RECTANGLE)
  isActive Boolean    @default(true)

  area            Area              @relation(fields: [areaId], references: [id], onDelete: Cascade)
  tableGroupLinks TableGroupTable[]
  reservations    TableReservation[]

  @@index([areaId])
}

enum TableShape {
  RECTANGLE
  ROUND
  SQUARE
}

model TableGroup {
  id         String @id @default(cuid())
  venueId    String
  name       String
  minPersons Int
  maxPersons Int

  venue  Venue             @relation(fields: [venueId], references: [id], onDelete: Cascade)
  tables TableGroupTable[]

  @@index([venueId])
}

model TableGroupTable {
  id           String @id @default(cuid())
  tableGroupId String
  tableId      String

  tableGroup TableGroup @relation(fields: [tableGroupId], references: [id], onDelete: Cascade)
  table      Table      @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@unique([tableGroupId, tableId])
}

// ═══════════════════════════════════════════════════════════════
// Zeitfenster & Kapazität
// ═══════════════════════════════════════════════════════════════

model TimeSlot {
  id        String  @id @default(cuid())
  venueId   String
  label     String?
  startTime String // "18:00"
  endTime   String? // "23:00"
  isActive  Boolean @default(true)

  venue    Venue     @relation(fields: [venueId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([venueId])
}

model DateConfig {
  id          String   @id @default(cuid())
  venueId     String
  date        DateTime @db.Date
  isBlocked   Boolean  @default(false)
  maxCapacity Int?
  note        String?

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([venueId, date])
}

model CapacityRule {
  id         String @id @default(cuid())
  venueId    String
  minPersons Int
  maxPersons Int
  tables     Int

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([venueId])
}

model SeasonConfig {
  id                   String   @id @default(cuid())
  venueId              String   @unique
  seasonStart          DateTime @db.Date
  seasonEnd            DateTime @db.Date
  activeWeekdays       Int[] // ISO weekdays [1..7]
  pricePerPerson       Decimal  @db.Decimal(10, 2)
  currency             String   @default("EUR")
  holdMinutes          Int      @default(15)
  maxPersonsPerBooking Int      @default(50)
  minPersonsPerBooking Int      @default(10)

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)
}

// ═══════════════════════════════════════════════════════════════
// Add-ons
// ═══════════════════════════════════════════════════════════════

model AddOn {
  id          String    @id @default(cuid())
  venueId     String
  name        String
  description String?
  price       Decimal   @db.Decimal(10, 2)
  priceType   PriceType @default(FLAT)
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)

  venue         Venue          @relation(fields: [venueId], references: [id], onDelete: Cascade)
  bookingAddOns BookingAddOn[]

  @@index([venueId])
}

enum PriceType {
  FLAT
  PER_PERSON
}

// ═══════════════════════════════════════════════════════════════
// Buchung
// ═══════════════════════════════════════════════════════════════

model Booking {
  id            String        @id @default(cuid())
  bookingNumber String        @unique
  venueId       String
  bookingType   BookingType   @default(TABLE_ONLY)
  timeSlotId    String?
  date          DateTime      @db.Date
  status        BookingStatus @default(HOLD)
  personCount   Int           @default(0)
  tableCount    Int           @default(0)
  curlingTotal  Decimal       @db.Decimal(10, 2) @default(0)

  // Kontaktdaten
  companyName String
  internalOrderNumber String?
  contactName String
  email       String
  phone       String
  address     String?
  vatId       String?
  notes       String?

  // Preise
  pricePerPerson Decimal @db.Decimal(10, 2)
  addOnsTotal    Decimal @db.Decimal(10, 2) @default(0)
  subtotal       Decimal @db.Decimal(10, 2)
  total          Decimal @db.Decimal(10, 2)
  currency       String  @default("EUR")

  // DSGVO
  consentGiven Boolean   @default(false)
  consentAt    DateTime?

  // Zeitsteuerung
  expiresAt   DateTime?
  confirmedAt DateTime?
  cancelledAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  venue               Venue                @relation(fields: [venueId], references: [id])
  timeSlot            TimeSlot?            @relation(fields: [timeSlotId], references: [id])
  addOns              BookingAddOn[]
  tableReservations   TableReservation[]
  curlingReservations CurlingReservation[]
  payment             Payment?
  adjustments         BookingAdjustment[]

  @@index([venueId, date])
  @@index([status])
  @@index([bookingNumber])
  @@index([email])
  @@index([date, timeSlotId])
}

enum BookingType {
  TABLE_ONLY
  CURLING_ONLY
  COMBINED
}

enum BookingStatus {
  HOLD
  PENDING
  CONFIRMED
  CANCELLED
  EXPIRED
}

model BookingAddOn {
  id        String  @id @default(cuid())
  bookingId String
  addOnId   String
  quantity  Int     @default(1)
  unitPrice Decimal @db.Decimal(10, 2)
  total     Decimal @db.Decimal(10, 2)

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  addOn   AddOn   @relation(fields: [addOnId], references: [id])

  @@index([bookingId])
}

model TableReservation {
  id        String            @id @default(cuid())
  bookingId String
  tableId   String
  date      DateTime          @db.Date
  status    ReservationStatus @default(HELD)

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  table   Table   @relation(fields: [tableId], references: [id])

  @@unique([tableId, date, bookingId])
  @@index([tableId, date])
  @@index([bookingId])
}

enum ReservationStatus {
  HELD
  CONFIRMED
  RELEASED
}

// ═══════════════════════════════════════════════════════════════
// Eisstockschießen
// ═══════════════════════════════════════════════════════════════

model CurlingLane {
  id       String  @id @default(cuid())
  venueId  String
  name     String // "Bahn 1", "Bahn 2"
  isActive Boolean @default(true)

  venue        Venue                @relation(fields: [venueId], references: [id], onDelete: Cascade)
  reservations CurlingReservation[]

  @@index([venueId])
}

model CurlingReservation {
  id            String            @id @default(cuid())
  bookingId     String
  curlingLaneId String
  date          DateTime          @db.Date
  startTime     String // "16:00"
  endTime       String // "17:00"
  pricePerHour  Decimal           @db.Decimal(10, 2)
  status        ReservationStatus @default(HELD)
  createdAt     DateTime          @default(now())

  booking     Booking     @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  curlingLane CurlingLane @relation(fields: [curlingLaneId], references: [id])

  @@unique([curlingLaneId, date, startTime])
  @@index([bookingId])
  @@index([curlingLaneId, date])
}

// ═══════════════════════════════════════════════════════════════
// Zahlung
// ═══════════════════════════════════════════════════════════════

model Payment {
  id                  String        @id @default(cuid())
  bookingId           String        @unique
  stripeSessionId     String?       @unique
  stripePaymentIntent String?       @unique
  amount              Decimal       @db.Decimal(10, 2)
  currency            String        @default("EUR")
  status              PaymentStatus @default(PENDING)
  paidAt              DateTime?
  refundedAt          DateTime?
  metadata            Json?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

model BookingAdjustment {
  id                  String                  @id @default(cuid())
  bookingId           String
  type                BookingAdjustmentType
  status              BookingAdjustmentStatus @default(PENDING)
  amount              Decimal                 @db.Decimal(10, 2)
  currency            String                  @default("EUR")
  stripeSessionId     String?                 @unique
  stripePaymentIntent String?                 @unique
  metadata            Json?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId, status])
}

enum BookingAdjustmentType {
  UPSIZE
  CANCELLATION_REFUND
}

enum BookingAdjustmentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

// ═══════════════════════════════════════════════════════════════
// Admin
// ═══════════════════════════════════════════════════════════════

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  role         AdminRole @default(STAFF)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  STAFF
}
